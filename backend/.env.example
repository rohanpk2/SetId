# Copy to `.env` for local Docker or uvicorn: `cp .env.example .env`
# Compose also injects DATABASE_URL / Celery URLs; defaults match docker-compose.yml.

DATABASE_URL=postgresql://postgres:postgres@db:5432/wealthsplit
JWT_SECRET_KEY=change-me-to-a-random-secret-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=1440

STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PUBLISHABLE_KEY=

OPENAI_API_KEY=
OPENAI_RECEIPT_VISION_MODEL=gpt-4.1
OPENAI_RECEIPT_CLEANUP_MODEL=gpt-4.1-mini

# Optional legacy Groq fallback
GROQ_API_KEY=
GROQ_BASE_URL=https://api.groq.com/openai/v1
GROQ_RECEIPT_VISION_MODEL=meta-llama/llama-4-scout-17b-16e-instruct
GROQ_RECEIPT_CLEANUP_MODEL=openai/gpt-oss-20b

UPLOAD_DIR=./uploads

CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

# ─── Test-login bypass (Apple review / QA / demos) ──────────────────
# Numbers in this list skip Twilio entirely and accept only TEST_OTP_CODE.
# Use fictitious US numbers (+1 555 01xx) so they can never collide with
# real SMS delivery. After adding these, run:
#   python -m scripts.seed_test_phones
# to create matching user rows (required for the "login" intent).
# TEST_PHONE_NUMBERS=["+15555550100","+15555550101"]
# TEST_OTP_CODE=424242
