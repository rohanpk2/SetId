# Copy to `.env` for local Docker or uvicorn: `cp .env.example .env`
# Compose also injects DATABASE_URL / Celery URLs; defaults match docker-compose.yml.

DATABASE_URL=postgresql://postgres:postgres@db:5432/wealthsplit
JWT_SECRET_KEY=change-me-to-a-random-secret-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=1440

STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PUBLISHABLE_KEY=

GROQ_API_KEY=
GROQ_BASE_URL=https://api.groq.com/openai/v1
GROQ_RECEIPT_VISION_MODEL=meta-llama/llama-4-scout-17b-16e-instruct
GROQ_RECEIPT_CLEANUP_MODEL=openai/gpt-oss-20b

UPLOAD_DIR=./uploads

CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0
